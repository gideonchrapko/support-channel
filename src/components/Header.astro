---
import Button from "./ui/Button.astro";
---

<header id="site-header">
  <div class="nav-bar">
    <div class="nav-left">
      <a href="/" class="logo" aria-label="Botpress home">
        <img src="/botpress-logo-dark.svg" alt="Botpress" class="logo-img" />
      </a>
      <nav class="nav-links" aria-label="Main navigation">
        <a href="#about" class="nav-link">About</a>
        <a href="#products" class="nav-link">Products</a>
        <a href="https://botpress.com/pricing" class="nav-link">Pricing</a>
        <a href="https://botpress.com/docs" class="nav-link">Documentation</a>
      </nav>
    </div>

    <div class="nav-right">
      <Button
        size="sm"
        href="https://botpress.com/contact-us?utm_source=support-channel&utm_medium=referral"
        class="nav-cta"
      >
        Contact Sales
      </Button>
      <button
        class="nav-toggle"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg
          class="icon-menu"
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M3 5h14M3 10h14M3 15h14"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
        <svg
          class="icon-close"
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M5 5l10 10M15 5L5 15"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-nav" class="mobile-nav" aria-hidden="true">
    <div class="mobile-nav-inner">
      <nav class="mobile-links" aria-label="Mobile navigation">
        <a href="#about" class="mobile-link">About</a>
        <a href="#products" class="mobile-link">Products</a>
        <a href="https://botpress.com/pricing" class="mobile-link">Pricing</a>
        <a href="https://botpress.com/docs" class="mobile-link">Documentation</a>
      </nav>
      <div class="mobile-actions">
        <Button
          href="https://botpress.com/contact-us?utm_source=support-channel&utm_medium=referral"
          class="mobile-cta-btn"
        >
          Contact Sales
        </Button>
      </div>
    </div>
  </div>
</header>

<style>
  /* ── Fixed wrapper ── */
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-3) clamp(1rem, 3vw, 1.2rem);
    gap: var(--space-2);
    pointer-events: none;
  }

  /* ── Nav pill ── */
  .nav-bar {
    pointer-events: auto;
    color: var(--color-text-primary);
    width: 100%;
    max-width: var(--container-wide);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-2) var(--space-2) var(--space-4);
    border-radius: var(--radius-2xl);
    background: color-mix(in srgb, var(--neutral-100) 0%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition:
      max-width 0.5s var(--ease-out),
      background 0.3s ease;
  }

  .nav-bar.is-scrolled {
    max-width: 52rem;
    background: color-mix(in srgb, var(--neutral-100) 80%, transparent);
  }

  /* ── Left ── */
  .nav-left {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .logo-img {
    height: 1.75rem;
    width: auto;
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: var(--space-1);
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-size: var(--step--1);
    font-weight: var(--fw-medium);
    color: var(--color-text-secondary);
    border-radius: var(--radius-lg);
    transition: background var(--transition-fast) ease,
      color var(--transition-fast) ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    background: color-mix(in srgb, currentColor 6%, transparent);
    color: var(--color-text-primary);
  }

  /* ── Right ── */
  .nav-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav-cta {
    display: none;
  }

  /* ── Hamburger toggle ── */
  .nav-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-lg);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-primary);
    transition: background var(--transition-fast) ease;
  }

  .nav-toggle:hover {
    background: color-mix(in srgb, currentColor 6%, transparent);
  }

  .icon-close {
    display: none;
  }

  .nav-toggle[aria-expanded="true"] .icon-menu {
    display: none;
  }

  .nav-toggle[aria-expanded="true"] .icon-close {
    display: block;
  }

  /* ── Mobile menu ── */
  .mobile-nav {
    pointer-events: none;
    width: 100%;
    max-width: var(--container-default);
    border-radius: var(--radius-2xl);
    border: 1px solid transparent;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    display: grid;
    grid-template-rows: 0fr;
    transition:
      grid-template-rows 0.3s var(--ease-out),
      max-width 0.5s var(--ease-out),
      border-color 0.2s ease,
      background 0.2s ease;
    overflow: hidden;
  }

  .mobile-nav.is-scrolled {
    max-width: 52rem;
  }

  .mobile-nav.is-open {
    pointer-events: auto;
    grid-template-rows: 1fr;
    border-color: color-mix(in srgb, var(--neutral-400) 25%, transparent);
    background: color-mix(in srgb, var(--neutral-50) 95%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .mobile-nav-inner {
    overflow: hidden;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .mobile-links {
    display: flex;
    flex-direction: column;
  }

  .mobile-link {
    padding: var(--space-3) var(--space-2);
    font-size: var(--step-0);
    font-weight: var(--fw-medium);
    color: var(--color-text-primary);
    border-radius: var(--radius-lg);
    border-bottom: 1px solid color-mix(in srgb, currentColor 8%, transparent);
    transition: background var(--transition-fast) ease;
  }

  .mobile-link:last-child {
    border-bottom: none;
  }

  .mobile-link:hover {
    background: color-mix(in srgb, currentColor 5%, transparent);
  }

  .mobile-actions {
    padding-top: var(--space-2);
  }

  .mobile-cta-btn {
    width: 100%;
    justify-content: center;
  }

  /* ── Desktop ── */
  @media (min-width: 48rem) {
    .nav-links {
      display: flex;
    }

    .nav-cta {
      display: inline-flex;
    }

    .nav-toggle {
      display: none;
    }

    .mobile-nav {
      display: none;
    }
  }
</style>

<script>
  const header = document.getElementById("site-header") as HTMLElement;
  const navBar = header?.querySelector<HTMLElement>(".nav-bar");
  const toggle = header?.querySelector<HTMLButtonElement>(".nav-toggle");
  const mobileNav = header?.querySelector<HTMLElement>(".mobile-nav");

  // ── Shrink pill on scroll ──
  const onScroll = () => {
    const scrolled = window.scrollY > 20;
    navBar?.classList.toggle("is-scrolled", scrolled);
    mobileNav?.classList.toggle("is-scrolled", scrolled);
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  // ── Mobile menu toggle ──
  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    const next = !isOpen;
    toggle.setAttribute("aria-expanded", String(next));
    mobileNav?.classList.toggle("is-open", next);
    mobileNav?.setAttribute("aria-hidden", String(!next));
    toggle.setAttribute(
      "aria-label",
      next ? "Close navigation menu" : "Open navigation menu",
    );
  });

  // ── Close on outside click ──
  document.addEventListener("click", (e) => {
    if (!header.contains(e.target as Node)) {
      toggle?.setAttribute("aria-expanded", "false");
      mobileNav?.classList.remove("is-open");
      mobileNav?.setAttribute("aria-hidden", "true");
    }
  });

  // ── Close on mobile link click ──
  mobileNav?.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      toggle?.setAttribute("aria-expanded", "false");
      mobileNav.classList.remove("is-open");
      mobileNav.setAttribute("aria-hidden", "true");
    });
  });
</script>
