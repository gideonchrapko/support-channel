<section id="about" class="about section">
  <div class="container container--narrow about-inner">
    <p class="eyebrow text-sm about-eyebrow">Platform</p>
    <h2 class="heading-h2 about-heading">About Botpress</h2>
    <div class="about-rule"></div>
    <p class="text-lg about-body">
      Botpress is an AI agent platform for <strong>building</strong>,{" "}
      <strong>deploying</strong>, and <strong>managing</strong> AI agents for
      business workflows.
    </p>
  </div>
</section>

<style>
  .about-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    padding-block: var(--space-12);
    border-top: 1px solid var(--color-highlight);
    border-bottom: 1px solid var(--color-highlight);
  }

  .about-eyebrow {
    color: var(--color-text-muted);
  }

  .about-heading {
    color: var(--color-text-primary);
  }

  .about-rule {
    width: 3rem;
    height: 1px;
    background: var(--color-border-accent);
  }

  .about-body {
    max-width: 52ch;
    color: var(--color-text-secondary);
  }

  .about-body strong {
    color: var(--color-text-primary);
    font-weight: var(--fw-semibold);
  }
</style>
