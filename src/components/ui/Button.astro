---
// src/components/ui/Button.astro
import ArrowRight from "./icons/ArrowRight.astro";

interface Props {
  /** Visual style. @default 'primary' */
  variant?: "primary" | "secondary";
  /** Size variant. @default 'md' */
  size?: "md" | "sm";
  /** Renders as <a> when provided; otherwise <button>. */
  href?: string;
  target?: string;
  rel?: string;
  /** button type — only applies when rendered as <button>. @default 'button' */
  type?: "button" | "submit" | "reset";
  /** Show arrow icon. @default false */
  arrow?: boolean;
  disabled?: boolean;
  class?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  target,
  rel: relProp,
  type = "button",
  arrow = false,
  disabled = false,
  class: className,
} = Astro.props;

const classes = [
  "btn",
  `btn--${variant}`,
  size === "sm" && "btn--sm",
  className,
]
  .filter(Boolean)
  .join(" ");

const rel =
  href && target === "_blank" ? (relProp ?? "noopener noreferrer") : relProp;
---

{
  href ? (
    <a
      class={classes}
      href={disabled ? undefined : href}
      target={target}
      rel={rel}
      aria-disabled={disabled ? "true" : undefined}
      tabindex={disabled ? -1 : undefined}
    >
      <slot />
      {arrow && (
        <span class="btn-arrow" aria-hidden="true">
          <span class="btn-arrow__icon">
            <ArrowRight />
          </span>
          <span class="btn-arrow__icon">
            <ArrowRight />
          </span>
        </span>
      )}
    </a>
  ) : (
    <button
      class={classes}
      type={type}
      disabled={disabled || undefined}
      aria-disabled={disabled ? "true" : undefined}
    >
      <slot />
      {arrow && (
        <span class="btn-arrow" aria-hidden="true">
          <span class="btn-arrow__icon">
            <ArrowRight />
          </span>
          <span class="btn-arrow__icon">
            <ArrowRight />
          </span>
        </span>
      )}
    </button>
  )
}

<style>
  /* ─── Base ── */

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    height: var(--btn-height);
    padding: 0 var(--btn-pad-x);
    border-radius: var(--radius-xl);
    border: 1px solid transparent;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-style: normal;
    font-weight: var(--fw-normal);
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background var(--transition-fast) var(--ease-out),
      border-color var(--transition-fast) var(--ease-out),
      color var(--transition-fast) var(--ease-out);
  }

  /* ─── Small ── */

  .btn--sm {
    height: var(--btn-height-sm);
    padding: 0 var(--btn-pad-x-sm);
    border-radius: var(--radius-lg);
  }

  .btn--sm .btn-arrow {
    width: 0.875rem;
    height: 0.875rem;
  }

  /* ─── Primary ── */

  .btn--primary {
    background: var(--foreground);
    color: var(--background);
  }

  .btn--primary:hover {
    background: var(--neutral-800);
  }

  /* ─── Secondary ── */

  .btn--secondary {
    background: transparent;
    color: var(--neutral-950);
    border-color: var(--neutral-300);
  }

  .btn--secondary:hover {
    background: var(--neutral-100);
    border-color: var(--neutral-400);
  }

  /* ─── Focus ── */

  .btn:focus-visible {
    outline: 2px solid var(--neutral-950);
    outline-offset: 3px;
  }

  .btn--secondary:focus-visible {
    outline-color: var(--neutral-700);
  }

  /* ─── Disabled ── */

  .btn:disabled,
  .btn[aria-disabled="true"] {
    opacity: 0.38;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ─── Arrow wrapper ── */

  .btn-arrow {
    position: relative;
    display: inline-flex;
    overflow: hidden;
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .btn-arrow__icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 200ms var(--ease-out);
  }

  .btn-arrow__icon:last-child {
    transform: translateX(-100%);
  }

  .btn:hover .btn-arrow__icon:first-child {
    transform: translateX(105%);
  }

  .btn:hover .btn-arrow__icon:last-child {
    transform: translateX(0);
  }

  /* ─── Reduced motion ── */

  @media (prefers-reduced-motion: reduce) {
    .btn-arrow__icon {
      transition: opacity var(--transition-fast);
      transform: none !important;
    }

    .btn-arrow__icon:last-child {
      opacity: 0;
    }

    .btn:hover .btn-arrow__icon:first-child {
      opacity: 0.5;
    }

    .btn:hover .btn-arrow__icon:last-child {
      opacity: 0;
    }
  }
</style>
