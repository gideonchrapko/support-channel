---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Botpress - Build and Deploy AI Agents',
  description = 'Botpress is an AI agent platform for building, deploying, and managing AI agents for business workflows.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-light-32x32.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-dark-32x32.png" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/apple-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline defer src="/_vercel/insights/script.js"></script>
  </head>
  <body>
    <slot />
  </body>
</html>
